rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Carteles de fiestas ────────────────────────────────────────────────
    // Ruta: carteles/{timestamp}.jpg
    match /carteles/{fileName} {
      // Las imágenes de fiestas son públicas
      allow read: if true;

      // Solo usuarios autenticados pueden subir (la autorización real
      // la da Firestore: solo admins pueden crear documentos de fiesta)
      // Límite: 8 MB, solo imágenes
      allow create: if request.auth != null
                    && request.resource.size < 8 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      // No se pueden sobreescribir ni borrar desde el cliente
      allow update, delete: if false;
    }

    // ── Fotos de perfil y banners ──────────────────────────────────────────
    // Ruta: perfiles/{uid}/photo.jpg  |  perfiles/{uid}/banner.jpg
    match /perfiles/{userId}/{fileName} {
      // Cualquier usuario autenticado puede ver fotos de perfil
      allow read: if request.auth != null;

      // Solo el propio usuario puede subir/actualizar su foto
      // Límite: 5 MB, solo imágenes
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Fotos de fiestas ───────────────────────────────────────────────────
    // Ruta: fotos/{fiestaId}/{uid}_{timestamp}.jpg
    // El nombre de archivo DEBE empezar por el UID del usuario que sube.
    match /fotos/{fiestaId}/{fileName} {
      // Cualquier usuario autenticado puede ver las fotos
      allow read: if request.auth != null;

      // Solo puede subir el usuario cuyo UID aparece al inicio del nombre
      // Límite: 10 MB, solo imágenes
      allow create: if request.auth != null
                    && fileName.matches(request.auth.uid + '.*')
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      // Solo el autor puede borrar su propia foto
      allow delete: if request.auth != null
                    && fileName.matches(request.auth.uid + '.*');

      // Las fotos no se pueden editar una vez subidas
      allow update: if false;
    }

    // ── Denegación por defecto ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
